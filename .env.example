# API Base URL
# Defaults to FakeRestAPI if not set
# Used in Docker containers and CI/CD pipelines
API_BASE_URL=https://fakerestapi.azurewebsites.net

# Debug mode
DEBUG=false

# Playwright Configuration (optional)
# BROWSER=chromium
# HEADED=false
# SLOW_MO=0
# TIMEOUT=30000

# Test Execution (optional)
# WORKERS=4
# RETRIES=2

